# PropFlow — environment variables (copy to .env.local and fill in)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Prisma -> Supabase pooled connection)
DATABASE_URL=
DIRECT_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=PropFlow <noreply@propflow.app>

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AI / BYOAI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Encryption
ENCRYPTION_KEY=

# ntfy push notifications (used by scripts/notify.sh)
NTFY_TOPIC=
NTFY_TOKEN=

# Linear
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# OAuth providers (configured in Supabase dashboard, listed here for reference)
# - Google
# - Apple
# - Microsoft (Azure)
