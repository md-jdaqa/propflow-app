{
  "name": "propflow-app",
  "version": "0.0.0",
  "private": true,
  "description": "PropFlow — AI-powered property management SaaS (dark-mode-first, mobile-first)",
  "repository": {
    "type": "git",
    "url": "https://github.com/mdarifuzzaman1116/propflow-app.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "playwright test --reporter=json,html",
    "posttest": "node scripts/log-results.js",
    "test:smoke": "PROPFLOW_PHASE=smoke playwright test --grep @smoke --reporter=json,html",
    "test:regression": "PROPFLOW_PHASE=regression playwright test --reporter=json,html",
    "test:desktop": "playwright test --project=\"Desktop Chrome\"",
    "test:mobile": "playwright test --project=\"Mobile iPhone 14\"",
    "test:tablet": "playwright test --project=\"Tablet iPad Pro\"",
    "test:status": "tail -40 TESTING.md",
    "test:install": "playwright install --with-deps chromium webkit",
    "version:patch": "bash scripts/version-bump.sh patch",
    "version:minor": "bash scripts/version-bump.sh minor",
    "version:major": "bash scripts/version-bump.sh major",
    "notify": "bash scripts/notify.sh",
    "linear": "node scripts/linear-sync.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "archiver": "^7.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "inngest": "^3.27.5",
    "lucide-react": "^1.14.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^4.0.1",
    "stripe": "^17.4.0",
    "tailwind-merge": "^2.5.4",
    "twilio": "^5.3.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/archiver": "^6.0.3",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
